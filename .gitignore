# Python 缓存
__pycache__/
*.py[cod]
*$py.class

# 虚拟环境
.venv/
venv/
env/
ENV/

# 构建产物
build/
dist/
*.egg-info/

# 日志
logs/
*.log

# 大规模实验原始结果：默认不直接提交
results/raw/*.csv
results/raw/*.xlsx
results/raw/*.pkl
results/raw/*.npy
results/raw/*.npz
results/raw/*.jsonl
results/curves/

# legacy 旧成果只允许手工精选后提交，不要整包推 GitHub
legacy/**/*.zip
legacy/**/*.rar
legacy/**/*.7z
legacy/**/*.tar
legacy/**/*.gz
legacy/**/*.csv
legacy/**/*.xlsx
legacy/**/*.pkl
legacy/**/*.npy
legacy/**/*.npz
legacy/**/*.pdf
legacy/**/*.png
legacy/**/*.jpg
legacy/**/*.jpeg
legacy/**/*.log
legacy/**/__pycache__/

# 如果确实要保留 legacy 目录结构，可以提交 .gitkeep、README、md、py、tex 等小文件
!legacy/**/.gitkeep
!legacy/**/*.md
!legacy/**/*.py
!legacy/**/*.tex
!legacy/**/*.bib
!legacy/**/*.txt

# 临时分析文件
results/tmp/
*.tmp
*.bak

# LaTeX 编译缓存
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.toc
*.lof
*.lot

# 系统文件
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# 不提交本地私有数据
local_data/
private_data/
